---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE } from '../consts';

// Renter-safe Reviews / Real Results page.
// No fabricated reviews, ratings, or photos — proof is populated from the renter as
// jobs complete. This page exists to (a) give /reviews/ a real destination (the llms.txt
// + location pages link here), and (b) hold the structure for real AggregateRating +
// Review schema once verified review data exists. Image gallery is intentionally omitted
// until real before/after photos are dropped into public/gallery/ (see the renter note below).

const title = `Real Results & Reviews — ${SITE.brand} (${SITE.city}, ${SITE.state})`;
const description = `Real work and customer feedback from ${SITE.brand} across ${SITE.city}, ${SITE.state} and nearby. Ask for recent references and photos with your free estimate.`;

const faqs = [
  { q: 'Can I see examples of your work before I book?', a: 'Yes. When you request a free written estimate, we will send recent photos and references from jobs similar to yours in your area.' },
  { q: 'Do you have online reviews I can read?', a: 'We collect feedback after every completed job. Request an estimate and we will share our most recent reviews and references.' },
  { q: 'How do I leave a review after my project?', a: 'After we finish, you will get a simple follow-up with a direct link to leave feedback. We read and reply to every review.' },
];

// FAQ schema.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// LocalBusiness placeholder — real AggregateRating + Review objects get added here ONLY
// when verified review data exists. Never fabricate ratings or review counts.
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.brand,
  // aggregateRating: { '@type': 'AggregateRating', ratingValue: 'X.X', reviewCount: 'NN' } // add with REAL data only
};
---

<BaseLayout title={title} description={description} path="/reviews/">
  <section class="hero">
    <div class="container">
      <h1>Real Results &amp; Reviews</h1>
      <p>
        See the kind of work {SITE.brand} delivers across {SITE.city}, {SITE.state} and the
        surrounding area. Every project starts with a free written estimate and a clear scope.
      </p>
      <div class="btn-row" style="margin-top:1.75rem">
        {SITE.phoneHref ? (
          <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
        ) : null}
        <a class="btn btn--call" href="/contact/">Get a Free Estimate</a>
      </div>
      <div class="trust" style="margin-top:1.25rem">
        <span>Local {SITE.city} work</span>
        <span>Insured &amp; careful</span>
        <span>References on request</span>
      </div>
    </div>
  </section>

  <!-- Social proof structure (renter populates with real feedback over time) -->
  <section class="section section--soft">
    <div class="container" style="max-width:820px">
      <div class="center">
        <h2>What Homeowners Say</h2>
        <p class="lead">We collect feedback after every job and reply to every review.</p>
      </div>

      <div class="proof-bar" style="margin-top:2rem">
        <div>
          <div class="proof-stars">★★★★★</div>
          <div class="proof-text">
            Real results from local {SITE.city}-area projects. Ask for recent references and
            photos with your free estimate.
          </div>
        </div>
      </div>

      <p style="margin-top:1.5rem">
        As we complete more projects, verified reviews and direct homeowner feedback will be
        featured here with full <strong>AggregateRating</strong> and <strong>Review</strong>
        schema so they can appear in search results.
      </p>

      <div style="margin-top:1.5rem">
        <a class="btn btn--primary" href="/contact/">Request Recent Photos &amp; References</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="center"><h2>Common Questions About Our Work</h2></div>
      <div class="faq" style="margin-top:2rem; max-width:780px; margin-left:auto; margin-right:auto;">
        {faqs.map((f) => (
          <details>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to get started?" />

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
</BaseLayout>
