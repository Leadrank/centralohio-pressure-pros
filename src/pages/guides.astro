---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, RESOURCES } from '../consts';
import { GUIDES_HUB } from '../content';
---

<BaseLayout title={GUIDES_HUB.metaTitle} description={GUIDES_HUB.metaDescription} path="/guides/">
  <section class="hero">
    <div class="container">
      <h1>{GUIDES_HUB.heroH1}</h1>
      <p>{GUIDES_HUB.heroSub}</p>
      <div class="btn-row" style="margin-top:1.75rem">
        {SITE.phoneHref ? (
          <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
        ) : (
          <a class="btn btn--primary" href="/contact/">Request a Free Estimate</a>
        )}
        <a class="btn btn--call" href="/contact/">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      <p>{GUIDES_HUB.intro}</p>
    </div>
    <div class="container" style="margin-top:1.5rem">
      <div class="grid">
        {RESOURCES.map((r) => (
          <div class="card">
            <a class="card-link" href={`/${r.slug}/`}><h3>{r.title}</h3><p>{r.blurb}</p></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading={GUIDES_HUB.ctaHeading} />
</BaseLayout>
