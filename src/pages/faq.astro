---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE } from '../consts';
import { FAQ_PAGE } from '../content';

const allFaqs = FAQ_PAGE.groups.flatMap((g) => [...g.faqs]);
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<BaseLayout title={FAQ_PAGE.metaTitle} description={FAQ_PAGE.metaDescription} path="/faq/">
  <section class="hero">
    <div class="container">
      <h1 set:html={FAQ_PAGE.heroH1} />
      <p>{FAQ_PAGE.heroSub}</p>
      <div class="btn-row" style="margin-top:1.5rem">
        {SITE.phoneHref ? (
          <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
        ) : (
          <a class="btn btn--primary" href="/contact/">Request a Free Estimate</a>
        )}
        <a class="btn btn--call" href="/contact/">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">
      {FAQ_PAGE.groups.map((g) => (
        <div style="margin-bottom:2rem">
          <h2>{g.heading}</h2>
          <div class="faq" style="margin-top:1rem">
            {g.faqs.map((f) => (
              <details><summary>{f.q}</summary><p set:html={f.a} /></details>
            ))}
          </div>
        </div>
      ))}
      <p>Still have a question? <a href="/contact/">Get in touch</a> — the estimate is always free.</p>
    </div>
  </section>

  <CtaBand heading={FAQ_PAGE.ctaHeading} />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
