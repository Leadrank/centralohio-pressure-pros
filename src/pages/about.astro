---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, SERVICE_AREAS } from '../consts';
import { ABOUT } from '../content';
// NOTE: drop in the real owner story, years in business, and credentials from the
// renter when signed — replace the generated placeholders in src/content.ts (ABOUT).
---

<BaseLayout title={ABOUT.metaTitle} description={ABOUT.metaDescription} path="/about/">
  <section class="hero">
    <div class="container">
      <h1>About {SITE.brand}</h1>
      <p set:html={ABOUT.heroSub} />
      <div class="btn-row" style="margin-top:1.5rem">
        {SITE.phoneHref ? (
          <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
        ) : (
          <a class="btn btn--primary" href="/contact/">Request a Free Estimate</a>
        )}
        <a class="btn btn--call" href="/contact/">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:800px">
      <h2>{ABOUT.bodyHeading}</h2>
      {ABOUT.bodyParagraphs.map((p) => <p set:html={p} />)}

      <h2 style="margin-top:2rem">{ABOUT.trustHeading}</h2>
      <div class="features" style="margin-top:1.5rem">
        {ABOUT.trustFeatures.map((f) => (
          <div class="feature"><h3>{f.title}</h3><p set:html={f.body} /></div>
        ))}
      </div>

      <h2 style="margin-top:2rem">Licensed, Insured &amp; Local Experts</h2>
      <p>
        We are fully licensed to operate in {SITE.stateLong} and carry comprehensive general liability insurance. Proof of licensing and current insurance certificates are available on request — simply ask when we provide your free written estimate.
      </p>
      <p>
        {/* OWNER/CREW BIO PLACEHOLDER — replace with real details from the renter once signed. Include owner name and story, years of experience, specific expertise with {SITE.city}-area {SITE.serviceNoun} (e.g. local conditions, HOAs, materials), crew qualifications, and any manufacturer certifications. Add a photo when available from the renter. */}
        The work is performed by experienced local professionals who specialize in {SITE.serviceNoun} for {SITE.city} and surrounding communities. We know the local conditions and standards.
      </p>
      <p>
        Real results and reviews build trust. Request your free estimate and we’ll share recent before-and-after photos from comparable jobs in your area plus customer references. On-page Google reviews and job-site proof are priorities as we grow our local track record. <strong>For the renter:</strong> Claim/verify your Google Business Profile right away (primary category: {SITE.serviceType}; appropriate secondaries). Post 1–2x weekly with geo-tagged before/after photos from each service area, ask every completed job for a 5-star review, and reply to every review within 24 hours — this is one of the highest-ROI local ranking signals.
      </p>

      <h2 style="margin-top:2rem">Proudly Serving the {SITE.city} Area</h2>
      <p>
        We provide {SITE.serviceNoun} throughout {SITE.city}, {SITE.stateLong} and nearby communities
        including {SERVICE_AREAS.join(', ')}. Not sure if we cover your neighborhood? Just ask.
      </p>
    </div>
  </section>

  <CtaBand heading={ABOUT.ctaHeading} />
</BaseLayout>
