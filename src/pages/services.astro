---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, SERVICES } from '../consts';
import { SERVICES_HUB } from '../content';
---

<BaseLayout title={SERVICES_HUB.metaTitle} description={SERVICES_HUB.metaDescription} path="/services/">
  <section class="hero">
    <div class="container">
      <h1>{SERVICES_HUB.heroH1}</h1>
      <p>{SERVICES_HUB.heroSub}</p>
      <div class="btn-row" style="margin-top:1.75rem">
        {SITE.phoneHref ? (
          <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
        ) : (
          <a class="btn btn--primary" href="/contact/">Request a Free Estimate</a>
        )}
        <a class="btn btn--call" href="/contact/">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid">
        {SERVICES.filter((s) => s.live).map((s) => (
          <div class="card">
            <a class="card-link" href={`/${s.slug}/`}><h3>{s.name}</h3><p>{s.short}</p></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
