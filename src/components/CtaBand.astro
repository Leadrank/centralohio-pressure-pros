---
import { SITE } from '../consts';
interface Props { heading?: string; sub?: string; }
const {
  heading = 'Get Your Free Estimate',
  sub = `Fast, friendly, no-obligation quotes for homeowners in ${SITE.city}, ${SITE.stateLong}.`,
} = Astro.props;
---
<section class="section cta-band">
  <div class="container center">
    <h2>{heading}</h2>
    <p class="lead">{sub}</p>
    <div class="btn-row" style="margin-top:1.25rem">
      {SITE.phoneHref ? (
        <a class="btn btn--primary" href={`tel:${SITE.phoneHref}`}>Call {SITE.phoneDisplay}</a>
      ) : (
        <a class="btn btn--primary" href="/contact/">Request a Free Estimate</a>
      )}
      <a class="btn btn--ghost" href="/contact/">Request Online</a>
    </div>
  </div>
</section>
